{
  "name": "github-deco",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "lint": "oxlint src test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "npm run typecheck && rm -rf dist && esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --sourcemap --outfile=dist/index.js"
  },
  "dependencies": {
    "hono": "^4.12.31",
    "simple-icons": "^16.27.0"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.11",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "oxlint": "^1.75.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
